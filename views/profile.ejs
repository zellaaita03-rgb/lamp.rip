<%- include('layout', { content: `
<div class="container">
  <h1 class="page-title mb-3">Settings</h1>
  
  ${typeof success !== 'undefined' && success ? `<div class="flash flash-success mb-2"><i class="fas fa-check-circle"></i> ${success}</div>` : ''}
  ${typeof error !== 'undefined' && error ? `<div class="flash flash-error mb-2"><i class="fas fa-exclamation-circle"></i> ${error}</div>` : ''}
  
  <div class="profile-content">
    <div class="card">
      <div class="profile-section">
        <h3 class="profile-section-title">
          <i class="fas fa-user"></i> Profile
        </h3>
        
        <div class="profile-header">
          <div class="profile-avatar" id="avatarContainer">
            ${user.portrait ? `<img src="/${user.portrait}" alt="${user.username}" id="avatarImg">` : user.username[0].toUpperCase()}
          </div>
          <div class="profile-info">
            <h2>${user.username}</h2>
            <p>Member</p>
          </div>
        </div>
        
        <div class="mt-2">
          <label class="form-label">Change Portrait</label>
          <input type="file" id="portraitInput" accept="image/*" style="display: none;" onchange="uploadPortrait(this)">
          <button class="btn btn-secondary" onclick="document.getElementById('portraitInput').click()">
            <i class="fas fa-upload"></i> Upload Photo
          </button>
          <p class="text-muted text-sm mt-1">JPG, PNG, GIF, WebP. Max 5MB.</p>
        </div>
      </div>
    </div>
    
    <div class="card">
      <div class="profile-section">
        <h3 class="profile-section-title">
          <i class="fas fa-birthday-cake"></i> Birthday
        </h3>
        <form method="POST" action="/profile" id="birthdayForm">
          <div class="form-group">
            <label class="form-label">Your Birthday</label>
            <div style="display: flex; gap: 0.5rem;">
              <select id="birthdayMonth" class="form-select" style="flex: 1;" onchange="updateBirthday()">
                <option value="">Month</option>
                <option value="01">January</option>
                <option value="02">February</option>
                <option value="03">March</option>
                <option value="04">April</option>
                <option value="05">May</option>
                <option value="06">June</option>
                <option value="07">July</option>
                <option value="08">August</option>
                <option value="09">September</option>
                <option value="10">October</option>
                <option value="11">November</option>
                <option value="12">December</option>
              </select>
              <select id="birthdayDay" class="form-select" style="flex: 1;" onchange="updateBirthday()">
                <option value="">Day</option>
                <option value="01">1</option><option value="02">2</option><option value="03">3</option><option value="04">4</option>
                <option value="05">5</option><option value="06">6</option><option value="07">7</option><option value="08">8</option>
                <option value="09">9</option><option value="10">10</option><option value="11">11</option><option value="12">12</option>
                <option value="13">13</option><option value="14">14</option><option value="15">15</option><option value="16">16</option>
                <option value="17">17</option><option value="18">18</option><option value="19">19</option><option value="20">20</option>
                <option value="21">21</option><option value="22">22</option><option value="23">23</option><option value="24">24</option>
                <option value="25">25</option><option value="26">26</option><option value="27">27</option><option value="28">28</option>
                <option value="29">29</option><option value="30">30</option><option value="31">31</option>
              </select>
              <input type="hidden" name="birthday" id="birthdayInput" value="${user.birthday || ''}">
            </div>
            <p class="text-muted text-sm mt-1">This will create recurring birthday events on the calendar!</p>
          </div>
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> Save Birthday
          </button>
        </form>
      </div>
    </div>
    
    <script>
    function updateBirthday() {
      const month = document.getElementById('birthdayMonth').value;
      const day = document.getElementById('birthdayDay').value;
      if (month && day) {
        document.getElementById('birthdayInput').value = month + '-' + day;
      }
    }
    (function() {
      const current = '${user.birthday || ''}';
      if (current) {
        const parts = current.split('-');
        if (parts.length === 2) {
          document.getElementById('birthdayMonth').value = parts[0];
          document.getElementById('birthdayDay').value = parts[1];
        }
      }
    })();
    </script>
    
    <div class="card">
      <div class="profile-section">
        <h3 class="profile-section-title">
          <i class="fas fa-lock"></i> Change Password
        </h3>
        
        <form method="POST" action="/profile">
          <div class="form-group">
            <label class="form-label" for="current_password">Current Password</label>
            <input type="password" id="current_password" name="current_password" class="form-input" required>
          </div>
          
          <div class="form-group">
            <label class="form-label" for="new_password">New Password</label>
            <input type="password" id="new_password" name="new_password" class="form-input" required minlength="6">
          </div>
          
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> Update Password
          </button>
        </form>
      </div>
    </div>
    
    <div class="card" id="wishlist">
      <div class="profile-section">
        <h3 class="profile-section-title">
          <i class="fas fa-gift"></i> My Wishlist
        </h3>
        
        <form method="POST" action="/add_wishlist_item" class="mb-3">
          <div class="grid grid-2" style="gap: 0.75rem;">
            <input type="url" name="url" class="form-input" placeholder="Product URL (optional)">
            <input type="text" name="custom_title" class="form-input" placeholder="Item name">
          </div>
          <button type="submit" class="btn btn-primary btn-sm mt-2">
            <i class="fas fa-plus"></i> Add Item
          </button>
        </form>
        
        ${typeof myWishlist !== 'undefined' && myWishlist.length > 0 ? `
        <div class="wishlist-grid">
          ${myWishlist.map(item => `
          <div class="wishlist-item">
            <h4 class="wishlist-item-title">${item.title}</h4>
            ${item.url ? `<div class="wishlist-item-url"><a href="${item.url}" target="_blank"><i class="fas fa-external-link-alt"></i> View</a></div>` : ''}
            <div class="wishlist-item-actions">
              <a href="/delete_wishlist_item/${item.id}" class="btn btn-danger btn-sm" onclick="return confirm('Remove?')">
                <i class="fas fa-trash"></i>
              </a>
            </div>
          </div>
          `).join('')}
        </div>
        ` : `
        <p class="text-muted">No items yet. Add something you want!</p>
        `}
      </div>
    </div>
  </div>
</div>

<script>
async function uploadPortrait(input) {
  if (input.files && input.files[0]) {
    const file = input.files[0];
    const reader = new FileReader();
    reader.onload = async function(e) {
      const img = new Image();
      img.onload = async function() {
        const canvas = document.createElement('canvas');
        const maxSize = 400;
        let width = img.width;
        let height = img.height;
        
        if (width > height) {
          if (width > maxSize) {
            height *= maxSize / width;
            width = maxSize;
          }
        } else {
          if (height > maxSize) {
            width *= maxSize / height;
            height = maxSize;
          }
        }
        
        canvas.width = width;
        canvas.height = height;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0, width, height);
        
        const dataUrl = canvas.toDataURL('image/jpeg', 0.8);
        
        try {
          const response = await fetch('/profile/portrait', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ image: dataUrl })
          });
          
          const result = await response.json();
          if (result.success) {
            document.getElementById('avatarContainer').innerHTML = 
              '<img src="' + result.path + '" alt="${user.username}" id="avatarImg">';
          } else {
            alert('Failed to upload: ' + (result.error || 'Unknown error'));
          }
        } catch (err) {
          alert('Upload failed: ' + err.message);
        }
      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
  }
}
</script>
`, page: 'profile' }) %>
