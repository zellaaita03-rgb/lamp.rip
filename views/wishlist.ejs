<%- include('layout', { content: `
<div class="container">
  <div class="page-header">
    <h1 class="page-title">Wishlists</h1>
  </div>
  
  <div class="wishlist-layout">
    <!-- Users Sidebar -->
    <div class="users-sidebar">
      <h3 class="sidebar-title">Users</h3>
      <div class="users-list">
        ${users.map(u => `
        <a href="/wishlist?user=${u.id}" class="user-item ${viewUser.id === u.id ? 'active' : ''}">
          <div class="user-avatar-sm">
            ${u.portrait ? `<img src="/${u.portrait}" alt="${u.username}">` : u.username[0].toUpperCase()}
          </div>
          <span>${u.username}${u.id === currentUserId ? ' (You)' : ''}</span>
        </a>
        `).join('')}
      </div>
    </div>
    
    <!-- Wishlist Content -->
    <div class="wishlist-content">
      <div class="wishlist-header">
        <h2>${viewUser.username}'s Wishlist</h2>
      </div>
      
      ${items.length > 0 ? `
      <div class="wishlist-grid">
        ${items.map(item => `
        <div class="wishlist-item">
          <h3 class="wishlist-item-title">${item.title}</h3>
          ${item.url ? `
          <div class="wishlist-item-url">
            <a href="${item.url}" target="_blank" rel="noopener">
              <i class="fas fa-external-link-alt"></i> View Product
            </a>
          </div>
          ` : ''}
        </div>
        `).join('')}
      </div>
      ` : `
      <div class="empty-state">
        <i class="fas fa-gift"></i>
        <h3>No items yet</h3>
        <p>This user hasn't added any items.</p>
      </div>
      `}
    </div>
  </div>
</div>

<style>
.wishlist-layout {
  display: grid;
  grid-template-columns: 250px 1fr;
  gap: 2rem;
}

@media (max-width: 768px) {
  .wishlist-layout {
    grid-template-columns: 1fr;
  }
}

.users-sidebar {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 1rem;
  height: fit-content;
}

.sidebar-title {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 1rem;
  color: var(--text-secondary);
}

.users-list {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.user-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem;
  border-radius: 10px;
  color: var(--text-primary);
  text-decoration: none;
  transition: all 0.2s ease;
}

.user-item:hover {
  background: var(--bg-tertiary);
}

.user-item.active {
  background: rgba(255, 107, 53, 0.1);
  color: var(--accent);
}

.user-avatar-sm {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--accent-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 0.8rem;
  overflow: hidden;
}

.user-avatar-sm img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.wishlist-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.5rem;
}

.wishlist-header h2 {
  font-size: 1.5rem;
}
</style>
`, page: 'wishlist' }) %>

<script>
function previewUrl() {
  const url = document.getElementById('url').value;
  if (url && !document.getElementById('custom_title').value) {
    document.getElementById('custom_title').placeholder = 'Fetching title...';
  }
}
</script>
